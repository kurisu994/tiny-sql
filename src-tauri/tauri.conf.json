{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "tiny-sql",
  "version": "0.0.1-rc3",
  "identifier": "com.kurisu.tiny-sql",
  "build": {
    "frontendDist": "../out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "tiny-sql",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; font-src 'self'; connect-src 'self'; object-src 'none'; frame-ancestors 'none';"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["dmg", "app"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDI5NjRENkQ2RjZGNDE0NDUKUldSRkZQVDIxdFprS2F4Ky9ZRDlRWS9qSldzay9STlBhZnl1bXhlcWFVS2l0c3JjYW1ESVV5NmkK",
      "endpoints": [
        "https://github.com/kurisu994/tiny-sql/releases/latest/download/latest.json"
      ]
    }
  }
}
